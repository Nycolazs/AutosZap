{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "node",
      "runtimeArgs": ["../node_modules/next/dist/bin/next", "dev"],
      "port": 3000,
      "cwd": "frontend",
      "env": {
        "BACKEND_URL": "https://api.autoszap.com",
        "NEXT_TELEMETRY_DISABLED": "1"
      }
    },
    {
      "name": "mobile",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--port", "8081"],
      "port": 8081,
      "cwd": "apps/mobile",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.autoszap.com"
      }
    }
  ]
}
