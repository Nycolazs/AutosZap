{
  "name": "@autoszap/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "lint": "expo lint",
    "doctor": "expo-doctor",
    "build:android": "eas build --platform android --profile production",
    "build:preview": "eas build --platform android --profile preview",
    "update:production": "eas update --channel production --message \"AutoZap mobile production update\"",
    "update:preview": "eas update --channel preview --message \"AutoZap mobile preview update\""
  },
  "dependencies": {
    "@autoszap/platform-client": "*",
    "@autoszap/platform-types": "*",
    "@expo/metro-runtime": "^55.0.6",
    "@expo/vector-icons": "^15.1.1",
    "@tanstack/react-query": "^5.90.21",
    "expo": "^55.0.6",
    "expo-constants": "^55.0.7",
    "expo-crypto": "^55.0.9",
    "expo-device": "^55.0.9",
    "expo-linking": "^55.0.7",
    "expo-notifications": "^55.0.12",
    "expo-router": "^55.0.5",
    "expo-secure-store": "^55.0.8",
    "expo-status-bar": "^55.0.4",
    "expo-updates": "^55.0.13",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.84.1",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-worklets": "0.7.2",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "typescript": "^5.9.3"
  },
  "expo": {
    "install": {
      "exclude": [
        "react",
        "react-dom",
        "react-native",
        "react-native-safe-area-context",
        "react-native-screens"
      ]
    }
  }
}
