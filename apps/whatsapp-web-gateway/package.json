{
  "name": "@autoszap/whatsapp-web-gateway",
  "version": "0.1.0",
  "private": true,
  "description": "AutosZap internal WhatsApp Web gateway",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "node --import tsx --test src/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "express": "^4.21.2",
    "qrcode": "^1.5.4",
    "puppeteer": "^24.16.0",
    "whatsapp-web.js": "^1.30.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^22.10.7",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
