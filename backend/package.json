{
  "name": "backend",
  "version": "0.0.1",
  "description": "AutosZap backend API",
  "author": "OpenAI Codex",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "prisma:generate": "npm run prisma:tenant:generate && npm run prisma:control:generate",
    "prisma:tenant:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:control:generate": "prisma generate --schema prisma/control-plane/schema.prisma",
    "prisma:tenant:push": "prisma db push --schema prisma/schema.prisma",
    "prisma:control:push": "prisma db push --schema prisma/control-plane/schema.prisma",
    "prisma:migrate:deploy": "npm run prisma:tenant:migrate:deploy && npm run prisma:control:migrate:deploy",
    "prisma:tenant:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "prisma:control:migrate:deploy": "prisma migrate deploy --schema prisma/control-plane/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema prisma/schema.prisma --name init",
    "prisma:control:migrate": "prisma migrate dev --schema prisma/control-plane/schema.prisma --name init_control_plane",
    "seed": "tsx prisma/seed.ts",
    "mt:migrate:control-plane": "tsx scripts/multitenancy/migrate-control-plane.ts",
    "mt:migrate:tenant": "tsx scripts/multitenancy/migrate-tenant.ts",
    "mt:migrate:all-tenants": "tsx scripts/multitenancy/migrate-all-tenants.ts",
    "mt:seed:control-plane": "tsx scripts/multitenancy/seed-control-plane.ts",
    "mt:seed:tenant": "tsx scripts/multitenancy/seed-tenant.ts",
    "mt:bootstrap:control-plane": "tsx scripts/multitenancy/bootstrap-control-plane.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.2.6",
    "@prisma/client": "^6.18.0",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.70.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "cookie-parser": "^1.4.7",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^6.18.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
