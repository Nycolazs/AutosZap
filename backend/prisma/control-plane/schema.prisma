generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/@autoszap/control-plane-client"
}

datasource db {
  provider = "postgresql"
  url      = env("CONTROL_PLANE_DATABASE_URL")
}

enum GlobalUserStatus {
  ACTIVE
  BLOCKED
  PENDING
}

enum PlatformRole {
  SUPER_ADMIN
  SUPPORT
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum MembershipStatus {
  ACTIVE
  INVITED
  INACTIVE
}

enum TenantRole {
  ADMIN
  MANAGER
  AGENT
  SELLER
}

enum TenantDatabaseStatus {
  PROVISIONING
  READY
  FAILED
  INACTIVE
}

enum ProvisioningJobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
}

enum PlatformAuditAction {
  LOGIN
  LOGIN_FAILED
  COMPANY_CREATED
  COMPANY_UPDATED
  COMPANY_PROVISIONED
  USER_CREATED
  USER_UPDATED
  MEMBERSHIP_CREATED
  MEMBERSHIP_UPDATED
  SECURITY_EVENT
}

enum InviteCodeStatus {
  ACTIVE
  USED
  EXPIRED
  REVOKED
}

enum LeadInterestStatus {
  PENDING
  CONTACTED
  CONVERTED
  ARCHIVED
}

model GlobalUser {
  id                       String                     @id @default(cuid())
  email                    String                     @unique
  name                     String
  passwordHash             String
  avatarUrl                String?
  status                   GlobalUserStatus           @default(ACTIVE)
  platformRole             PlatformRole?
  blockedAt                DateTime?
  lastLoginAt              DateTime?
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt
  deletedAt                DateTime?
  memberships              CompanyMembership[]
  refreshTokens            GlobalRefreshToken[]
  passwordResetTokens      GlobalPasswordResetToken[]
  auditLogs                PlatformAuditLog[]         @relation("PlatformAuditActor")
  requestedProvisioningJobs TenantProvisioningJob[]   @relation("ProvisioningRequestedBy")
  supportTickets           SupportTicket[]
  supportTicketMessages    SupportTicketMessage[]     @relation("SupportTicketMessageSender")
}

model Company {
  id               String                @id @default(cuid())
  slug             String                @unique
  name             String
  legalName        String?
  status           CompanyStatus         @default(ACTIVE)
  workspaceId      String                @unique
  segment          String?
  featureFlags     Json?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  deactivatedAt    DateTime?
  memberships      CompanyMembership[]
  tenantDatabase   TenantDatabase?
  provisioningJobs TenantProvisioningJob[]
  refreshTokens    GlobalRefreshToken[]
  inviteCodes      CompanyInviteCode[]
  supportTickets   SupportTicket[]
}

model CompanyMembership {
  id           String           @id @default(cuid())
  companyId    String
  globalUserId String
  tenantRole   TenantRole       @default(SELLER)
  status       MembershipStatus @default(ACTIVE)
  isDefault    Boolean          @default(false)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  revokedAt    DateTime?
  company      Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  globalUser   GlobalUser       @relation(fields: [globalUserId], references: [id], onDelete: Cascade)

  @@unique([companyId, globalUserId])
  @@index([globalUserId, status])
  @@index([companyId, status])
}

model TenantDatabase {
  id                   String               @id @default(cuid())
  companyId            String               @unique
  databaseName         String
  databaseHost         String?
  databasePort         Int?
  databaseSchema       String?
  connectionUrlEncrypted String
  status               TenantDatabaseStatus @default(PROVISIONING)
  provisionedAt        DateTime?
  lastMigrationAt      DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  company              Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model GlobalRefreshToken {
  id          String    @id @default(cuid())
  globalUserId String
  companyId   String?
  tokenHash   String    @unique
  expiresAt   DateTime
  revokedAt   DateTime?
  userAgent   String?
  ipAddress   String?
  createdAt   DateTime  @default(now())
  globalUser  GlobalUser @relation(fields: [globalUserId], references: [id], onDelete: Cascade)
  company     Company?   @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([globalUserId, expiresAt])
  @@index([companyId, expiresAt])
}

model GlobalPasswordResetToken {
  id          String    @id @default(cuid())
  globalUserId String
  tokenHash   String    @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())
  globalUser  GlobalUser @relation(fields: [globalUserId], references: [id], onDelete: Cascade)

  @@index([globalUserId, expiresAt])
}

model TenantProvisioningJob {
  id            String               @id @default(cuid())
  companyId     String
  requestedById String?
  status        ProvisioningJobStatus @default(QUEUED)
  attempt       Int                  @default(1)
  startedAt     DateTime?
  finishedAt    DateTime?
  errorMessage  String?
  metadata      Json?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  company       Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  requestedBy   GlobalUser?          @relation("ProvisioningRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
}

model PlatformAuditLog {
  id          String             @id @default(cuid())
  actorId     String?
  action      PlatformAuditAction
  entityType  String
  entityId    String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime           @default(now())
  actor       GlobalUser?        @relation("PlatformAuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([action, createdAt])
  @@index([entityType, entityId, createdAt])
}

model LeadInterest {
  id              String             @id @default(cuid())
  name            String
  email           String
  phone           String?
  companyName     String?
  attendantsCount Int?
  notes           String?
  source          String?
  status          LeadInterestStatus @default(PENDING)
  contactedAt     DateTime?
  convertedAt     DateTime?
  archivedAt      DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([status, createdAt])
  @@index([createdAt])
  @@index([email])
}

model CompanyInviteCode {
  id                  String           @id @default(cuid())
  companyId           String
  code                String           @unique
  role                TenantRole       @default(SELLER)
  title               String?
  workspaceRoleId     String?
  workspaceRoleName   String?
  status              InviteCodeStatus @default(ACTIVE)
  usedByGlobalUserId  String?
  createdByGlobalUserId String?
  createdAt           DateTime         @default(now())
  expiresAt           DateTime?
  usedAt              DateTime?
  company             Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, status])
  @@index([code])
}

enum SupportTicketCategory {
  IMPROVEMENT
  BUG
  QUESTION
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum SupportTicketMessageSenderType {
  CUSTOMER
  PLATFORM
}

model SupportTicket {
  id              String                 @id @default(cuid())
  companyId       String
  globalUserId    String
  title           String
  body            String
  category        SupportTicketCategory
  status          SupportTicketStatus    @default(OPEN)
  companyName     String
  authorName      String
  authorEmail     String
  resolvedAt      DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  company         Company                @relation(fields: [companyId], references: [id])
  author          GlobalUser             @relation(fields: [globalUserId], references: [id])
  messages        SupportTicketMessage[]

  @@index([companyId, status])
  @@index([globalUserId])
  @@index([status, createdAt])
}

model SupportTicketMessage {
  id                String                         @id @default(cuid())
  ticketId          String
  senderGlobalUserId String?
  senderType        SupportTicketMessageSenderType
  senderName        String
  senderEmail       String?
  body              String
  createdAt         DateTime                       @default(now())
  updatedAt         DateTime                       @updatedAt
  ticket            SupportTicket                  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender            GlobalUser?                    @relation("SupportTicketMessageSender", fields: [senderGlobalUserId], references: [id], onDelete: SetNull)

  @@index([ticketId, createdAt])
  @@index([senderGlobalUserId])
}
