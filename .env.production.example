POSTGRES_DB=autoszap
POSTGRES_USER=autoszap
POSTGRES_PASSWORD=change-me-strong-postgres-password
PORT=4000
FRONTEND_URL=https://your-frontend-domain.com
BACKEND_PUBLIC_URL=https://api.your-domain.com
CONTROL_PLANE_DATABASE_URL=postgresql://autoszap:change-me-strong-postgres-password@postgres:5432/autoszap_control?schema=public
DATABASE_URL=postgresql://autoszap:change-me-strong-postgres-password@postgres:5432/autoszap?schema=public
TENANT_DATABASE_STRATEGY=dedicated
TENANT_DATABASE_BASE_URL=postgresql://autoszap:change-me-strong-postgres-password@postgres:5432/autoszap?schema=public
TENANT_DATABASE_ADMIN_URL=postgresql://autoszap:change-me-strong-postgres-password@postgres:5432/postgres?schema=public
TENANT_DATABASE_PREFIX=autozap_tenant
TENANT_ALLOW_SHARED_FALLBACK=false

# Token do GitHub para resolver download de assets do Releases (necessario se o repo for privado).
# Deve ser um PAT com permissão de leitura no repositório.
GITHUB_RELEASES_TOKEN=change-me-github-token
GITHUB_RELEASES_REPO=Nycolazs/AutosZap
GITHUB_WINDOWS_ASSET_NAME=autoszap-setup-latest.exe
JWT_ACCESS_SECRET=change-me-random-64-char-hex
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
APP_ENCRYPTION_KEY=change-me-random-64-char-hex
REDIS_URL=redis://redis:6379
SWAGGER_ENABLED=false

# Hostname do backend exposto pelo Caddy (ex.: api.autoszap.com)
AUTOSZAP_BACKEND_HOST=api.your-domain.com
AUTOSZAP_BACKEND_FALLBACK_HOST=

META_MODE=DEV
META_GRAPH_API_VERSION=v23.0
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_BUSINESS_ACCOUNT_ID=
META_WHATSAPP_WEBHOOK_VERIFY_TOKEN=change-me-verify-token
META_APP_ID=
META_APP_SECRET=
META_EMBEDDED_SIGNUP_CONFIG_ID=
